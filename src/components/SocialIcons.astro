---
import { Icon } from '@astrojs/starlight/components';

// This component overrides Starlight's default SocialIcons for every page,
// both /en/ and /zh-cn/. Read the current page's locale so the "Blog" label
// isn't hardcoded to one language.
const { lang } = Astro.locals.starlightRoute;
const isZhCn = lang?.toLowerCase().startsWith('zh');

const blogLabel = isZhCn ? '博客' : 'Blog';
---

<div class="social-icons">

  <a
    href="https://github.com/shane00413-wq/shane-docs"
    aria-label="GitHub"
  >
    <Icon name="github" />
    <span>GitHub</span>
  </a>

  <a
    href="https://shane-blog.pages.dev"
    aria-label={blogLabel}
  >
    <Icon name="astro" />
    <span>{blogLabel}</span>
  </a>

</div>

<style>
.social-icons {
  display: flex;
  align-items: center;
  gap: 16px;
}

.social-icons a {
  display: flex;
  align-items: center;
  gap: 6px;
  color: inherit;
  text-decoration: none;
  white-space: nowrap;
  font-size: 0.9rem;
}

.social-icons svg {
  width: 18px;
  height: 18px;
}

.social-icons a:hover {
  opacity: 0.7;
}
</style>